{
  "name": "@iinm/plain-agent",
  "version": "1.6.1",
  "description": "A lightweight CLI-based coding agent",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iinm/plain-agent.git"
  },
  "bin": {
    "plain": "./bin/plain",
    "plain-interrupt": "./bin/plain-interrupt",
    "plain-notify-desktop": "./bin/plain-notify-desktop",
    "plain-notify-terminal-bell": "./bin/plain-notify-terminal-bell",
    "plain-sandbox": "./sandbox/bin/plain-sandbox"
  },
  "files": [
    "bin",
    "sandbox/bin",
    ".config",
    "src/**/*.mjs",
    "src/**/*.d.ts",
    "!src/**/*.test.mjs",
    "!src/**/*.playground.mjs",
    "!src/utils/test/"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "npm run lint && tsc && npm run test",
    "test": "node --test",
    "lint": "npx @biomejs/biome check",
    "fix": "npx @biomejs/biome check --fix"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/credential-providers": "^3.1026.0",
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/client": "^2.0.0-alpha.2",
    "@smithy/protocol-http": "^5.3.13",
    "@smithy/signature-v4": "^5.3.13",
    "diff": "^8.0.4",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3"
  }
}
